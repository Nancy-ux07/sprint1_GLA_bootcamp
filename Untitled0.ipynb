      "source": [
        "marks = [45, 60, 72, 38, 90]\n",
        "\n",
        "total = 0\n",
        "\n",
        "for i in range(len(marks) - 1):\n",
        "    total += marks[i]\n",
        "\n",
        "average = total / len(marks)\n",
        "\n",
        "if average > 50:\n",
        "    print(\"Class passed\")\n",
        "else:\n",
        "    print(\"Class failed\")\n",
        "\n",
        "print(\"average\",average)"
      ]
